# systemd user unit: keeps the Session Launcher web dashboard running.
# Install under ~/.config/systemd/user/ and enable with `systemctl --user`.
# %h expands to the user's home directory, so this unit stays username-generic.
[Unit]
Description=Session Launcher dashboard (portal-web.py)

[Service]
ExecStart=/usr/bin/env python3 %h/.claude-launcher/bin/portal-web.py
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
